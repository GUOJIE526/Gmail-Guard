{
  "manifest_version": 3,
  "name": "Gmail Guard",
  "short_name": "Gmail Guard",
  "version": "1.0.3",
  "description": "Highlights suspicious unread messages on the current Gmail or Outlook page with local phishing-risk hints.",
  "minimum_chrome_version": "114",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "Gmail Guard",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "options_page": "options.html",
  "permissions": ["storage"],
  "host_permissions": ["https://safebrowsing.googleapis.com/*"],
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*",
        "https://outlook.com/*",
        "https://www.outlook.com/*"
      ],
      "js": ["src/rules.js", "src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
